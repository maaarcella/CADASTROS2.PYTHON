import os

opcao = 0

pessoa_nome = []
pessoa_email = []
pessoa_telefone = []

while opcao != 4:

    print("------MENU------")
    print("1 - Cadastrar usuário")
    print("2 - Listar usuários")
    print("3 - Excluir usuário")
    print("4 - Sair do sistema")
    print("5 - Alterar cadastro")

    opcao = int(input("Escolha sua opção: "))

    if opcao == 1:
        nome = input("Digite seu nome completo: ")
        pessoa_nome.append(nome)

        email = input("Digite seu email: ")
        pessoa_email.append(email)

        telefone = input("Digite o seu telefone: ")
        pessoa_telefone.append(telefone)

        print("Usuário cadastrado com sucesso!")
        input("Pressione ENTER para continuar...")
        os.system("cls")


    elif opcao == 2:
        print("-----------USUÁRIOS----------")

        if len(pessoa_nome) == 0:
            print("Nenhum usuário cadastrado.")
        else:
            for i, (nome, email, telefone) in enumerate(zip(pessoa_nome, pessoa_email, pessoa_telefone)):
                print(f"{i} - Nome: {nome}")
                print(f"    Email: {email}")
                print(f"    Telefone: {telefone}")
                print("-----------------------------")

        input("Pressione ENTER para continuar...")
        os.system("cls")


    elif opcao == 3:
        print("-----------EXCLUIR USUÁRIO----------")

        if len(pessoa_nome) == 0:
            print("Nenhum usuário para excluir.")
        else:
            for i, nome in enumerate(pessoa_nome):
                print(f"{i} - {nome}")

            excluir = int(input("Digite o número do usuário que deseja excluir: "))

            if excluir >= 0 and excluir < len(pessoa_nome):
                pessoa_nome.pop(excluir)
                pessoa_email.pop(excluir)
                pessoa_telefone.pop(excluir)
                print("Usuário removido com sucesso!")
            else:
                print("Número inválido!")

        input("Pressione ENTER para continuar...")
        os.system("cls")


    elif opcao == 5:
        print("-----------ALTERAR USUÁRIO----------")

        if len(pessoa_nome) == 0:
            print("Nenhum usuário cadastrado.")
        else:
            for i, nome in enumerate(pessoa_nome):
                print(f"{i} - {nome}")

            indice = int(input("Digite o número do usuário que deseja alterar: "))

            if indice >= 0 and indice < len(pessoa_nome):

                print("O que deseja alterar?")
                print("1 - Nome")
                print("2 - Email")
                print("3 - Telefone")

                escolha = int(input("Escolha: "))

                if escolha == 1:
                    novo_nome = input("Digite o novo nome: ")
                    pessoa_nome[indice] = novo_nome

                elif escolha == 2:
                    novo_email = input("Digite o novo email: ")
                    pessoa_email[indice] = novo_email

                elif escolha == 3:
                    novo_telefone = input("Digite o novo telefone: ")
                    pessoa_telefone[indice] = novo_telefone

                else:
                    print("Opção inválida!")

                print("Dados atualizados com sucesso!")

            else:
                print("Número inválido!")

        input("Pressione ENTER para continuar...")
        os.system("cls")


    elif opcao == 4:
        print("SISTEMA ENCERRADO")
        break


    else:
        print("Opção inválida!")
        input("Pressione ENTER para continuar...")
        os.system("cls")
